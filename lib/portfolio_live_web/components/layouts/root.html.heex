<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      content="A Elite Estrangeira. Nós sabemos o que somos, onde podemos chegar e o que podemos realizar. Somos uma comunidade discreta que se reúne em busca de conhecimento, elevação pessoal e expansão cultural, trazendo a verdadeira luz do conhecimento àqueles capazes de questionar o suficiente para buscá-la."
      name="description"
    />
    <.live_title
      default="Seja bem vindo!"
      suffix=" - Portfolio do Kauã Silbershlach Parodes - Site Oficial"
    >
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/133865f2485a8c29.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/3b25ddb074f183be.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/68989b8edc203dc6.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/7976e287dece7a25.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/7c0b7f75750ab849.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/d5df9398139f9aea.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/data-vaul-drawer.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/db43014524f01bc2.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/f099702a7371bad3.css"} />
    <style>
      /* Customer logo carousel inserted below the Dark Web Monitoring CTA */
        .customer-carousel-module__pFnISG__carouselWrapper {
          width: 100%;
          overflow: hidden;
          margin: 0 auto 32px;
          padding: 0 24px;
          box-sizing: border-box;
        }

        .customer-carousel-module__pFnISG__carousel {
          position: relative;
          width: 100%;
          overflow: hidden;
          --slide-gap: 64px;
        }

        .customer-carousel-module__pFnISG__track {
          display: flex;
          align-items: center;
          gap: 0;
          width: max-content;
          will-change: transform;
          animation-name: customer-carousel-scroll;
          animation-timing-function: linear;
          animation-iteration-count: infinite;
        }

        .customer-carousel-module__pFnISG__slides {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: var(--slide-gap);
          list-style: none;
          margin: 0;
          padding: 0;
          min-width: max-content;
          flex: 0 0 auto;
        }

        .customer-carousel-module__pFnISG__slides li {
          flex: 0 0 auto;
        }

        .customer-carousel-module__pFnISG__slides img {
          display: block;
          height: auto;
          max-width: none;
        }

        @keyframes customer-carousel-scroll {
          from {
            transform: translate3d(0, 0, 0);
          }

          to {
            transform: translate3d(calc(-100% / var(--copies, 2)), 0, 0);
          }
        }

        @media (max-width: 768px) {
          .customer-carousel-module__pFnISG__carousel {
            --slide-gap: 40px;
          }

          .customer-carousel-module__pFnISG__carouselWrapper {
            padding: 0 16px;
            margin-bottom: 24px;
          }
        }

        @media (prefers-reduced-motion: reduce) {
          .customer-carousel-module__pFnISG__track {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
          }
        }

        .forensic-main-shell {
          min-height: calc(100svh - var(--header-height));
          border-bottom: 1px solid var(--ds-gray-alpha-400);
          margin-bottom: 90px;
        }

        .forensic-main-wrapper {
          --forensic-wrapper-inline-padding: 0px;
          --forensic-sidebar-collapsed-width: 10px;
          width: 100%;
          max-width: var(--ds-page-width-with-margin);
          margin: 0 auto;
        }

        .forensic-main-grid {
          width: 100%;
          display: flex;
          align-items: flex-start;
          justify-content: flex-start;
          gap: 0;
        }

        .forensic-left-sidebar {
          flex: 0 0 300px;
          min-width: 300px;
          width: 300px;
        }

        .forensic-left-sidebar[data-collapsed="true"] {
          flex-basis: var(--forensic-sidebar-collapsed-width) !important;
          min-width: var(--forensic-sidebar-collapsed-width) !important;
          width: var(--forensic-sidebar-collapsed-width) !important;
          padding-right: 0 !important;
        }

        .forensic-content-column {
          flex: 1 1 auto;
          min-width: 0;
          width: 100%;
        }

        .forensic-right-sidebar {
          flex: 0 0 240px;
          min-width: 240px;
        }

        .forensic-content-column .content-module__6uRq_q__fullwidth {
          max-width: 1100px;
        }

        @media (max-width: 1280px) {
          .forensic-main-wrapper {
            max-width: 100%;
          }
        }

        @media (max-width: 1150px) {
          .forensic-main-wrapper {
            --forensic-wrapper-inline-padding: var(--geist-gap);
            padding-left: var(--forensic-wrapper-inline-padding);
            padding-right: var(--forensic-wrapper-inline-padding);
          }

          .forensic-main-grid {
            display: flex;
            align-items: flex-start;
          }

          .forensic-content-column .reference-module__6VJ9GG__content,
          .forensic-content-column .content-module__6uRq_q__content {
            max-width: 100%;
            padding-left: 0;
            padding-right: 0;
          }
        }

        @media (max-width: 960px) {
          .forensic-main-shell {
            margin-bottom: 64px;
          }

          .forensic-main-wrapper {
            --forensic-wrapper-inline-padding: 16px;
            padding-left: var(--forensic-wrapper-inline-padding);
            padding-right: var(--forensic-wrapper-inline-padding);
          }

          .forensic-main-grid {
            display: block;
          }
        }

        .forensic-mobile-nav-toggle {
          display: none;
        }

        @media (max-width: 1023px) {
          .forensic-mobile-nav-toggle {
            display: flex;
            margin-left: calc(var(--forensic-wrapper-inline-padding) * -1);
            margin-right: calc(var(--forensic-wrapper-inline-padding) * -1);
            width: calc(100% + (var(--forensic-wrapper-inline-padding) * 2));
            box-sizing: border-box;
          }

          body.docs-mobile-nav-open {
            overflow: hidden;
          }

          body.docs-mobile-nav-open footer {
            display: none !important;
          }

          body.docs-mobile-nav-open .forensic-main-shell {
            margin-bottom: 0 !important;
            min-height: calc(100svh - var(--header-height)) !important;
          }

          body.docs-mobile-nav-open .forensic-main-grid {
            min-height: calc(100svh - var(--header-height));
            align-content: flex-start;
          }

          body.docs-mobile-nav-open #docs-main-content {
            display: none;
          }

          body.docs-mobile-nav-open #forensicNavAiSidebar {
            display: flex !important;
            position: relative !important;
            top: auto !important;
            height: calc(100svh - var(--header-height) - 55px) !important;
            max-height: calc(100svh - var(--header-height) - 55px) !important;
            min-height: calc(100svh - var(--header-height) - 55px) !important;
            width: 100% !important;
            min-width: 0 !important;
            flex: 1 1 auto !important;
            padding-right: 0 !important;
            overflow: hidden !important;
          }

          body.docs-mobile-nav-open #forensicNavAiSidebar[data-collapsed="true"] {
            flex-basis: auto !important;
            min-width: 0 !important;
            width: 100% !important;
          }

          body.docs-mobile-nav-open #forensicNavAiSidebarNav {
            opacity: 1 !important;
            visibility: visible !important;
            pointer-events: auto !important;
            height: 100% !important;
            max-height: 100% !important;
            overflow-x: hidden;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
          }
        }

        @media (max-width: 480px) {
          .forensic-main-wrapper {
            --forensic-wrapper-inline-padding: 12px;
            padding-left: var(--forensic-wrapper-inline-padding);
            padding-right: var(--forensic-wrapper-inline-padding);
          }
        }

        body[data-auth-role="authenticatedUser"] .auth-guest-only {
          display: none !important;
        }

        body[data-auth-role="guest"] .auth-user-only {
          display: none !important;
        }

        .auth-menu-form,
        .auth-menu-button {
          width: 100%;
        }

        .auth-menu-button {
          transition: background-color 150ms ease, color 150ms ease;
        }

        .auth-menu-button:hover,
        .auth-menu-button:focus-visible {
          background: var(--ds-gray-100);
        }

        .dark-theme .auth-menu-button:hover,
        .dark-theme .auth-menu-button:focus-visible {
          background: var(--ds-gray-200);
        }

        .forensic-mobile-header-menu {
          display: none;
        }

        @media (max-width: 1150px) {
          body.header-mobile-menu-open {
            overflow: hidden;
          }

          body.header-mobile-menu-open footer {
            display: none !important;
          }

          body.header-mobile-menu-open .forensic-mobile-nav-toggle {
            display: none !important;
          }

          body.header-mobile-menu-open .forensic-main-shell {
            min-height: 0 !important;
          }

          body.header-mobile-menu-open #mobile-header-menu-panel {
            display: block;
          }

          #mobile-menu-toggle {
            position: relative;
            z-index: 40;
          }

          #mobile-header-menu-panel {
            position: fixed;
            inset: 0;
            z-index: 5000;
            background: var(--ds-background-100);
            color: var(--ds-gray-1000);
          }

          #mobile-header-menu-panel[hidden] {
            display: none !important;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__surface {
            height: 100%;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: var(--ds-background-100);
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__top {
            display: flex;
            justify-content: flex-end;
            padding: 16px 16px 8px;
            flex: 0 0 auto;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__body {
            flex: 1 1 auto;
            min-height: 0;
            overflow-y: auto;
            padding: 8px 16px 24px;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__ctas {
            display: grid;
            gap: 12px;
            margin-bottom: 26px;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__nav,
          #mobile-header-menu-panel .forensic-mobile-header-menu__nav ul {
            list-style: none;
            margin: 0;
            padding: 0;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__nav > ul {
            display: grid;
            gap: 4px;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section {
            margin: 0;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-trigger,
          #mobile-header-menu-panel .forensic-mobile-header-menu__link {
            width: 100%;
            min-height: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 10px 12px;
            border: 0;
            border-radius: 0;
            background: transparent;
            color: var(--ds-gray-900);
            text-decoration: none;
            font-size: 16px;
            font-weight: 400;
            line-height: 1.5;
            letter-spacing: -0.01em;
            text-align: left;
            cursor: pointer;
            transition: color 150ms ease, opacity 150ms ease;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-trigger:hover,
          #mobile-header-menu-panel .forensic-mobile-header-menu__link:hover {
            color: var(--ds-gray-1000);
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-trigger[data-state="open"] {
            color: var(--ds-gray-1000);
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-trigger svg {
            transition: transform 150ms ease, color 150ms ease;
            flex: 0 0 auto;
            color: var(--ds-gray-800);
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-trigger[data-state="open"] svg {
            transform: rotate(90deg);
            color: var(--ds-gray-1000);
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-panel {
            display: none;
            margin: 2px 0 10px;
            max-height: min(42vh, 320px);
            overflow-y: auto;
            padding: 0 0 0 12px;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-panel[data-state="open"] {
            display: block;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-panel > ul {
            display: grid;
            gap: 2px;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-panel a {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 8px 0;
            border-radius: 0;
            color: var(--ds-gray-900);
            text-decoration: none;
            line-height: 1.4;
            transition: color 150ms ease, opacity 150ms ease;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-panel a:hover {
            color: var(--ds-gray-1000);
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__section-panel a svg {
            flex: 0 0 auto;
            margin-top: 2px;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__item-copy {
            min-width: 0;
            flex: 1 1 auto;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__item-title {
            display: block;
            color: inherit;
            font-size: 14px;
            font-weight: 400;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__item-description {
            display: none;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__theme {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-top: 14px;
            padding: 16px 12px;
            border-top: 1px solid var(--ds-gray-alpha-400);
            border-bottom: 1px solid var(--ds-gray-alpha-400);
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__theme p {
            margin: 0;
            font-size: 16px;
            font-weight: 400;
            color: var(--ds-gray-900);
            line-height: 1.5;
            letter-spacing: -0.01em;
          }

          #mobile-header-menu-panel .forensic-mobile-header-menu__theme .theme-switcher-module__q-SprW__root {
            margin-left: auto;
          }
        }

        /* Customer logo carousel inserted below the Dark Web Monitoring CTA */
        .customer-carousel-module__pFnISG__carouselWrapper {
          width: 100%;
          overflow: hidden;
          margin: 0 auto 32px;
          padding: 0 24px;
          box-sizing: border-box;
        }

        .customer-carousel-module__pFnISG__carousel {
          position: relative;
          width: 100%;
          overflow: hidden;
          --slide-gap: 64px;
        }

        .customer-carousel-module__pFnISG__track {
          display: flex;
          align-items: center;
          gap: 0;
          width: max-content;
          will-change: transform;
          animation-name: customer-carousel-scroll;
          animation-timing-function: linear;
          animation-iteration-count: infinite;
        }

        .customer-carousel-module__pFnISG__slides {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: var(--slide-gap);
          list-style: none;
          margin: 0;
          padding: 0;
          min-width: max-content;
          flex: 0 0 auto;
        }

        .customer-carousel-module__pFnISG__slides li {
          flex: 0 0 auto;
        }

        .customer-carousel-module__pFnISG__slides img {
          display: block;
          height: auto;
          max-width: none;
        }

        @keyframes customer-carousel-scroll {
          from {
            transform: translate3d(0, 0, 0);
          }

          to {
            transform: translate3d(calc(-100% / var(--copies, 2)), 0, 0);
          }
        }

        @media (max-width: 768px) {
          .customer-carousel-module__pFnISG__carousel {
            --slide-gap: 40px;
          }

          .customer-carousel-module__pFnISG__carouselWrapper {
            padding: 0 16px;
            margin-bottom: 24px;
          }
        }

        @media (prefers-reduced-motion: reduce) {
          .customer-carousel-module__pFnISG__track {
            animation-duration: 0.01ms !important;
            animation-iteration-count: 1 !important;
          }
        }
    </style>
    <.theme_bootstrap current_mode="system" settings={%{}} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>

  <body
    data-access-control={assigns[:app_access_control_json] || ~s({"currentRole":"guest"})}
    data-auth-role={assigns[:app_access_role] || "guest"}
  >
    <div class="forensic-shell">
      <div
        class="header-module__6nzVrW__wrapper header-module__6nzVrW__sticky"
        data-navigation-header=""
      >
        <header class="header-module__6nzVrW__header [--ds-page-width-with-margin:100%] max-w-[calc(var(--ds-page-width)+calc(2*var(--geist-page-margin)))]">
          <div class="header-module__6nzVrW__left flex items-center min-w-0">
            <div class="hidden min-[1150px]:flex items-center shrink-0">
              <span class="flex flex-row gap-2 items-center home-links">
                <a
                  aria-label="Home"
                  class="text-zinc-800 dark:text-zinc-100 -translate-y-[.5px] pl-4"
                  href="#"
                  rel="noopener"
                  target="_blank"
                >
                  <svg
                    aria-hidden="true"
                    class="block shrink-0"
                    width="18"
                    height="18"
                    fill="none"
                    viewBox="485 451 230 200"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      fill="var(--geist-background, transparent)"
                      d="M485 650.4h230L600 451.21z"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="1"
                      d="M715 650.4 L600 451.21 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.93"
                      d="M715 650.4 L600 460.33 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.87"
                      d="M715 650.4 L600 469.44 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.8"
                      d="M715 650.4 L600 478.56 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.73"
                      d="M715 650.4 L600 487.67 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.67"
                      d="M715 650.4 L600 496.79 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.6"
                      d="M715 650.4 L600 505.9 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.53"
                      d="M715 650.4 L600 515.02 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.47"
                      d="M715 650.4 L600 524.13 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.4"
                      d="M715 650.4 L600 533.25 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.33"
                      d="M715 650.4 L600 542.36 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.27"
                      d="M715 650.4 L600 551.48 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.2"
                      d="M715 650.4 L600 560.59 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.13"
                      d="M715 650.4 L600 569.71 L485 650.4"
                    >
                    </path>

                    <path
                      stroke="var(--geist-foreground, currentColor)"
                      opacity="0.07"
                      d="M715 650.4 L600 578.82 L485 650.4"
                    >
                    </path>
                  </svg>
                </a>
                <div
                  aria-hidden="true"
                  class="w-4 text-lg text-center text-zinc-300 dark:text-zinc-600"
                >
                  <svg
                    data-testid="geist-icon"
                    height="16"
                    stroke-linejoin="round"
                    style="color:currentColor"
                    viewbox="0 0 16 16"
                    width="16"
                  >
                    <path
                      clip-rule="evenodd"
                      d="M4.01526 15.3939L4.3107 14.7046L10.3107 0.704556L10.6061 0.0151978L11.9849 0.606077L11.6894 1.29544L5.68942 15.2954L5.39398 15.9848L4.01526 15.3939Z"
                      fill="currentColor"
                      fill-rule="evenodd"
                    >
                    </path>
                  </svg>
                </div>

                <a
                  aria-label="A Elite Estrangeira IDS"
                  class="text-zinc-800 dark:text-zinc-100 min-w-max"
                  href="#"
                >
                  <svg
                    class="shrink-0"
                    fill="none"
                    height="16"
                    style="overflow:visible;display:block"
                    viewbox="0 0 1555 90"
                    width="200"
                    xmlns="http://www.w3.org/2000/svg"
