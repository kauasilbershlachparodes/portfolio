<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#ffffff" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/login.css"} />
    <script phx-no-curly-interpolation>
      (function () {
        const STORAGE_KEY = 'theme-preference';
        const FALLBACK_MODE = 'system';
        const THEME_COLORS = { light: '#ffffff', dark: '#0a1729' };

        const root = document.documentElement;
        const metaThemeColor = document.querySelector('meta[name="theme-color"]');

        function normalizeTheme(value) {
          const normalized = String(value || '').trim().toLowerCase();
          return normalized === 'light' || normalized === 'dark' || normalized === 'system'
            ? normalized
            : FALLBACK_MODE;
        }

        function getStoredTheme() {
          try { return normalizeTheme(localStorage.getItem(STORAGE_KEY)); }
          catch (_error) { return FALLBACK_MODE; }
        }

        function resolveTheme(mode) {
          if (mode === 'system') {
            return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
          }
          return mode;
        }

        function applyTheme(mode) {
          const safeMode = normalizeTheme(mode);
          const resolvedMode = resolveTheme(safeMode);
          const isDark = resolvedMode === 'dark';

          root.classList.toggle('dark-theme', isDark);
          root.classList.toggle('light-theme', !isDark);
          root.style.colorScheme = resolvedMode;
          root.setAttribute('data-theme-mode', safeMode);
          root.setAttribute('data-theme-resolved', resolvedMode);
          root.setAttribute('data-theme-bootstrapped', 'true');

          if (metaThemeColor) {
            metaThemeColor.setAttribute('content', THEME_COLORS[resolvedMode] || THEME_COLORS.light);
          }
        }

        applyTheme(getStoredTheme());
      })();
    </script>

    <script phx-no-curly-interpolation>
      window.__ILLUMINATI_SUPABASE_CONFIG__ = {
        supabaseUrl: "https://yeuojewjvyfxcxqzxnpc.supabase.co",
        supabaseKey: "sb_publishable_K5uvJz80GZoBiZ6GqxpeXw__XCwKAsU",
        signUpRedirect: "/login?signup=success",
        resetRedirect: "/reset-password",
        loginSuccessRedirect: "/",
        authBootstrapStorageKey: "illuminati-auth-bootstrap",
        recoveryEmailStorageKey: "illuminati-recovery-email"
      };
    </script>

    <title>Illuminati Dark Web Monitoring</title>

    <style>
      .invict-login-submit[disabled],
      .invict-login-submit[aria-disabled="true"] {
        cursor: default !important;
      }
    </style>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/133865f2485a8c29.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/3b25ddb074f183be.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/68989b8edc203dc6.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/7976e287dece7a25.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/7c0b7f75750ab849.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/d5df9398139f9aea.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/data-vaul-drawer.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/db43014524f01bc2.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/f099702a7371bad3.css"} />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
    />
  </head>

  <body>
    <main class="invict-login-page">
      <section class="invict-login-shell" aria-labelledby="invict-reset-title">
        <header class="invict-login-brand" aria-label="Invict brand">
          <a
            class="invict-login-brand-link"
            href={~p"/login"}
            aria-label="Ir para a tela de login"
          >
            <span class="invict-login-brand-wordmark">
              <strong>A Elite Estrangeira</strong> <small>by Invicti</small>
            </span>
            <span class="invict-login-brand-tagline">AppSec with Zero Noise</span>
          </a>
        </header>

        <section class="invict-login-card" aria-label="Painel de redefinição de senha">
          <div class="invict-login-card-inner">
            <h1 id="invict-reset-title" class="invict-login-title">Create a new password</h1>

            <p class="invict-login-description">
              Choose a new password for <strong id="resetPasswordEmailValue">your account</strong>.
            </p>

            <form
              class="invict-login-form"
              id="invictResetPasswordForm"
              novalidate
              accept-charset="UTF-8"
            >
              <div class="invict-login-field">
                <label class="invict-login-label" for="resetPassword">New password</label>
                <input
                  class="invict-login-input"
                  id="resetPassword"
                  name="password"
                  type="password"
                  autocomplete="new-password"
                  maxlength="1024"
                  required
                  autofocus
                />
                <p class="invict-login-error" id="resetPasswordError" hidden>
                  Use pelo menos 8 caracteres.
                </p>
              </div>

              <div class="invict-login-field">
                <label class="invict-login-label" for="resetPasswordConfirm">
                  Repeat password
                </label>
                <input
                  class="invict-login-input"
                  id="resetPasswordConfirm"
                  name="password_confirmation"
                  type="password"
                  autocomplete="new-password"
                  maxlength="1024"
                  required
                />
                <p class="invict-login-error" id="resetPasswordConfirmError" hidden>
                  As senhas precisam ser iguais.
                </p>

                <p class="invict-login-error" id="invictAuthStatus" hidden></p>
              </div>

              <button
                class="button-module__QyrFCa__base button-module__QyrFCa__button button-module__QyrFCa__large invict-login-submit"
                type="submit"
                id="resetPasswordSubmitButton"
                data-geist-button
              >
                <span class="button-module__QyrFCa__content button-module__QyrFCa__center">
                  Save new password
                </span>
              </button>
              <div class="invict-login-options" style="justify-content: center; margin-top: 16px;">
                <a
                  class="link-module__Q1NRQq__link"
                  href={~p"/login"}
                  aria-label="Cancelar e voltar para login"
                >
                  Back to login
                </a>
              </div>
            </form>

            <section
              id="resetPasswordInvalidState"
              class="invict-login-form"
              hidden
              aria-live="polite"
            >
              <p class="invict-login-error" id="resetPasswordInvalidMessage">
                Recovery link inválido ou expirado.
              </p>

              <div
                class="invict-login-options"
                style="justify-content: center; margin-top: 16px; gap: 10px; flex-wrap: wrap;"
              >
                <a
                  class="link-module__Q1NRQq__link link-module__Q1NRQq__highlight"
                  href={~p"/forgot-password"}
                >
                  Request a new recovery link
                </a>
                <a class="link-module__Q1NRQq__link" href={~p"/login"}>Back to login</a>
              </div>
            </section>
          </div>
        </section>
      </section>

      <footer class="invict-login-footer" aria-label="Links legais">
        <nav class="invict-login-footer-links">
          <a class="link-module__Q1NRQq__link link-module__Q1NRQq__highlight" href="/copyright">
            Copyright © 2026 Invicti
          </a>
          <a
            class="link-module__Q1NRQq__link link-module__Q1NRQq__highlight"
            href="/privacy-policy"
          >
            Privacy Policy
          </a>
          <a
            class="link-module__Q1NRQq__link link-module__Q1NRQq__highlight"
            href="/data-protection-policy"
          >
            Data Protection Policy
          </a>
        </nav>
      </footer>
    </main>

    <script phx-no-curly-interpolation>
      (function () {
        function createSupabaseRestClient(cfg) {
          const authState = { session: null };

          function extractErrorMessage(payload, fallbackMessage) {
            if (payload && typeof payload === "object") {
              const candidate =
                payload.msg ||
                payload.error_description ||
                payload.message ||
                (typeof payload.error === "string" ? payload.error : "");

              if (candidate) {
                return String(candidate);
              }
            }

            return fallbackMessage || "Não foi possível concluir a operação de autenticação.";
          }

          async function request(path, options) {
            const cfgOptions = options && typeof options === "object" ? options : {};
            const method = String(cfgOptions.method || "GET").toUpperCase();
            const headers = Object.assign(
              {
                accept: "application/json",
                apikey: cfg.supabaseKey
              },
              cfgOptions.headers || {}
            );

            if (method !== "GET" && !headers["content-type"]) {
              headers["content-type"] = "application/json";
            }

            if (cfgOptions.accessToken) {
              headers.authorization = `Bearer ${cfgOptions.accessToken}`;
            }

            const response = await fetch(`${cfg.supabaseUrl}${path}`, {
              method,
              headers,
              body: cfgOptions.body == null ? undefined : JSON.stringify(cfgOptions.body)
            });

            const contentType = response.headers.get("content-type") || "";
            const payload = contentType.includes("application/json")
              ? await response.json().catch(function () { return {}; })
              : { message: await response.text().catch(function () { return ""; }) };

            if (!response.ok) {
              return {
                data: null,
                error: new Error(extractErrorMessage(payload, cfgOptions.fallbackMessage))
              };
            }

            return { data: payload, error: null };
          }

          function toSession(payload) {
            if (!payload || typeof payload !== "object") {
              return null;
            }

            if (!payload.access_token) {
              return null;
            }

            return {
              access_token: payload.access_token,
              refresh_token: payload.refresh_token || "",
              token_type: payload.token_type || "bearer",
              expires_in: payload.expires_in,
              expires_at: payload.expires_at,
              user: payload.user || null
            };
          }

          return {
            auth: {
              async signInWithPassword(credentials) {
                const email = credentials && credentials.email ? credentials.email : "";
                const password = credentials && credentials.password ? credentials.password : "";

                const result = await request("/auth/v1/token?grant_type=password", {
                  method: "POST",
                  body: { email, password },
                  fallbackMessage: "Não foi possível entrar."
                });

                if (result.error) {
                  return { data: { session: null, user: null }, error: result.error };
                }

                const session = toSession(result.data);
                authState.session = session;
                return { data: { session, user: session ? session.user : null }, error: null };
              },

              async signUp(payload) {
                const email = payload && payload.email ? payload.email : "";
                const password = payload && payload.password ? payload.password : "";
                const redirectTo = payload && payload.options ? payload.options.emailRedirectTo : undefined;

                const result = await request("/auth/v1/signup", {
                  method: "POST",
                  body: {
                    email,
                    password,
                    email_redirect_to: redirectTo
                  },
                  fallbackMessage: "Não foi possível criar a conta."
                });

                if (result.error) {
                  return { data: { session: null, user: null }, error: result.error };
                }

                const session = toSession(result.data);
                authState.session = session;
                return {
                  data: {
                    session,
                    user: (result.data && result.data.user) || (session && session.user) || null
                  },
                  error: null
                };
              },

              async resetPasswordForEmail(email, options) {
                const redirectTo = options && options.redirectTo ? options.redirectTo : undefined;

                const result = await request("/auth/v1/recover", {
                  method: "POST",
                  body: {
                    email,
                    redirect_to: redirectTo
                  },
                  fallbackMessage: "Não foi possível enviar o link de recuperação."
                });

                return result.error
                  ? { data: null, error: result.error }
                  : { data: result.data, error: null };
              },

              async getSession() {
                return { data: { session: authState.session }, error: null };
              },

              async setSession(payload) {
                authState.session = {
                  access_token: payload && payload.access_token ? payload.access_token : "",
                  refresh_token: payload && payload.refresh_token ? payload.refresh_token : "",
                  user: null
                };

                const userResult = await this.getUser();

                if (userResult.error) {
                  authState.session = null;
                  return { data: { session: null }, error: userResult.error };
                }

                if (authState.session) {
                  authState.session.user = userResult.data ? userResult.data.user : null;
                }

                return { data: { session: authState.session }, error: null };
              },

              async getUser() {
                const accessToken = authState.session && authState.session.access_token
                  ? authState.session.access_token
                  : "";

                if (!accessToken) {
                  return {
                    data: { user: null },
                    error: new Error("Sessão inválida ou expirada.")
                  };
                }

                const result = await request("/auth/v1/user", {
                  method: "GET",
                  accessToken,
                  fallbackMessage: "Não foi possível carregar o usuário autenticado."
                });

                return result.error
                  ? { data: { user: null }, error: result.error }
                  : { data: { user: result.data || null }, error: null };
              },

              async updateUser(attributes) {
                const accessToken = authState.session && authState.session.access_token
                  ? authState.session.access_token
                  : "";

                if (!accessToken) {
                  return {
                    data: { user: null },
                    error: new Error("Sessão inválida ou expirada.")
                  };
                }

                const result = await request("/auth/v1/user", {
                  method: "PUT",
                  accessToken,
                  body: attributes || {},
                  fallbackMessage: "Não foi possível atualizar o usuário."
                });

                if (result.error) {
                  return { data: { user: null }, error: result.error };
                }

                if (authState.session) {
                  authState.session.user = result.data || authState.session.user;
                }

                return { data: { user: result.data || null }, error: null };
              },

              async signOut() {
                authState.session = null;
                return { error: null };
              }
            }
          };
        }

        window.__ILLUMINATI_CREATE_SUPABASE_CLIENT__ = createSupabaseRestClient;
      })();
    </script>

    <script phx-no-curly-interpolation>
          document.addEventListener("DOMContentLoaded", function () {
        const cfg = window.__ILLUMINATI_SUPABASE_CONFIG__;
        const supabase = window.__ILLUMINATI_CREATE_SUPABASE_CLIENT__(cfg);

        const form = document.getElementById("invictResetPasswordForm");
        const invalidState = document.getElementById("resetPasswordInvalidState");
        const invalidMessage = document.getElementById("resetPasswordInvalidMessage");
        const passwordInput = document.getElementById("resetPassword");
        const confirmInput = document.getElementById("resetPasswordConfirm");
        const submitButton = document.getElementById("resetPasswordSubmitButton");
        const statusBox = document.getElementById("invictAuthStatus");
        const passwordError = document.getElementById("resetPasswordError");
        const confirmError = document.getElementById("resetPasswordConfirmError");
        const emailNode = document.getElementById("resetPasswordEmailValue");
        const descriptionNode = document.querySelector("#invict-reset-title + .invict-login-description");

        if (!form || !passwordInput || !confirmInput || !submitButton) return;

        function showStatus(message, tone) {
          if (!statusBox) return;
          statusBox.textContent = message || "";
          statusBox.hidden = !message;
          statusBox.style.color = tone === "success" ? "#067647" : "";
        }

        function showFieldError(node, show, message) {
          if (!node) return;
          if (message) node.textContent = message;
          node.hidden = !show;
        }

        function showExpiredState(message) {
          form.hidden = true;
          form.setAttribute("aria-hidden", "true");
          if (invalidState) {
            invalidState.hidden = false;
            invalidState.setAttribute("aria-hidden", "false");
          }
          if (descriptionNode) {
            descriptionNode.textContent = "This recovery link cannot be used anymore.";
          }
          const finalMessage = message || "Recovery link inválido ou expirado.";
          showStatus(finalMessage, "error");
          if (invalidMessage) invalidMessage.textContent = finalMessage;
        }

        function hasExplicitRecoveryError() {
          const hashParams = new URLSearchParams(window.location.hash.replace(/^#/, ""));
          const error = hashParams.get("error");
          const errorCode = hashParams.get("error_code");
          return Boolean(error || errorCode);
        }

        let resetSubmitted = false;
        let resetPasswordTouched = false;
        let resetConfirmTouched = false;

        function getPasswordErrorMessage(value) {
          const password = String(value || "");

          if (!password) {
            return "Use pelo menos 8 caracteres.";
          }

          if (password.length < 8) {
            return "Use pelo menos 8 caracteres.";
          }

          return "";
        }

        function getConfirmErrorMessage(password, confirmation) {
          const passwordValue = String(password || "");
          const confirmValue = String(confirmation || "");

          if (!confirmValue) {
            return "Repita sua senha.";
          }

          if (confirmValue !== passwordValue) {
            return "As senhas precisam ser iguais.";
          }

          return "";
        }

        function validateForm(options) {
          const settings = options && typeof options === "object" ? options : {};
          const forceShow = settings.forceShow === true;
          const password = passwordInput.value;
          const passwordConfirm = confirmInput.value;
          const passwordMessage = getPasswordErrorMessage(password);
          const confirmMessage = getConfirmErrorMessage(password, passwordConfirm);

          showFieldError(passwordError, Boolean(passwordMessage) && (forceShow || resetSubmitted || resetPasswordTouched), passwordMessage || "Use pelo menos 8 caracteres.");
          showFieldError(confirmError, Boolean(confirmMessage) && (forceShow || resetSubmitted || resetConfirmTouched), confirmMessage || "As senhas precisam ser iguais.");

          passwordInput.setAttribute("aria-invalid", String(Boolean(passwordMessage) && (resetSubmitted || resetPasswordTouched)));
          confirmInput.setAttribute("aria-invalid", String(Boolean(confirmMessage) && (resetSubmitted || resetConfirmTouched)));
          return !passwordMessage && !confirmMessage;
        }

        async function ensureRecoverySession() {
          if (hasExplicitRecoveryError()) {
            const hashParams = new URLSearchParams(window.location.hash.replace(/^#/, ""));
            throw new Error(hashParams.get("error_description") || "Recovery link inválido ou expirado.");
          }

          const existing = await supabase.auth.getSession();
          if (existing.data && existing.data.session) {
            return existing.data.session;
          }

          const hashParams = new URLSearchParams(window.location.hash.replace(/^#/, ""));
          const accessToken = hashParams.get("access_token");
          const refreshToken = hashParams.get("refresh_token");

          if (!accessToken || !refreshToken) {
            throw new Error("Recovery link inválido ou expirado.");
          }

          const { data, error } = await supabase.auth.setSession({
            access_token: accessToken,
            refresh_token: refreshToken
          });

          if (error) {
            throw error;
          }

          if (window.history && window.history.replaceState) {
            window.history.replaceState({}, document.title, window.location.pathname);
          }

          return data.session;
        }

        async function loadCurrentUser() {
          const session = await ensureRecoverySession();
          if (!session) {
            throw new Error("Não foi possível abrir a sessão de recuperação.");
          }

          const { data, error } = await supabase.auth.getUser();
          if (error) {
            throw error;
          }

          const email = data && data.user ? data.user.email || "" : "";

          if (emailNode && email) {
            emailNode.textContent = email;
          }

          if (email) {
            try {
              localStorage.setItem(cfg.recoveryEmailStorageKey, email);
            } catch (_error) {
              // no-op
            }
          }

          return email;
        }

        passwordInput.addEventListener("input", validateForm);
        confirmInput.addEventListener("input", validateForm);
        passwordInput.addEventListener("blur", function () {
          resetPasswordTouched = true;
          validateForm();
        });
        confirmInput.addEventListener("blur", function () {
          resetConfirmTouched = true;
          validateForm();
        });
        submitButton.disabled = false;
        submitButton.setAttribute("aria-disabled", "false");
        validateForm();

        let recoveredEmail = "";

        loadCurrentUser()
          .then(function (email) {
            recoveredEmail = email || "";
            if (!recoveredEmail) {
              try {
                recoveredEmail = localStorage.getItem(cfg.recoveryEmailStorageKey) || "";
                if (emailNode && recoveredEmail) {
                  emailNode.textContent = recoveredEmail;
                }
              } catch (_error) {
                // no-op
              }
            }
          })
          .catch(function (error) {
            showExpiredState(error.message || "Recovery link inválido ou expirado.");
          });

        form.addEventListener("submit", async function (event) {
          event.preventDefault();

          showStatus("", "error");
          resetSubmitted = true;
          resetPasswordTouched = true;
          resetConfirmTouched = true;
          if (!validateForm({ forceShow: true })) return;

          try {
            await ensureRecoverySession();
          } catch (error) {
            showExpiredState(error.message || "Recovery link inválido ou expirado.");
            return;
          }

          const newPassword = passwordInput.value;
          const { error } = await supabase.auth.updateUser({ password: newPassword });

          if (error) {
            showStatus(error.message || "Não foi possível atualizar a senha.", "error");
            return;
          }

          if (!recoveredEmail) {
            try {
              recoveredEmail = localStorage.getItem(cfg.recoveryEmailStorageKey) || "";
            } catch (_error) {
              recoveredEmail = "";
            }
          }

          try {
            sessionStorage.setItem(
              cfg.authBootstrapStorageKey,
              JSON.stringify({
                email: recoveredEmail,
                password: newPassword,
                createdAt: Date.now()
              })
            );
          } catch (_error) {
            // no-op
          }

          try {
            localStorage.removeItem(cfg.recoveryEmailStorageKey);
          } catch (_error) {
            // no-op
          }

          try {
            await supabase.auth.signOut();
          } catch (_error) {
            // no-op
          }

          window.location.href = "/login?reset=success";
        });
      });
        
    </script>
  </body>
</html>
